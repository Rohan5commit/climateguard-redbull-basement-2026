# Required for advisory generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional backup advisory provider (used when Gemini is unavailable)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# Free public data sources used by the app (no keys required):
# - OSM Nominatim
# - FEMA OpenFEMA
# - NOAA/NWS alerts
